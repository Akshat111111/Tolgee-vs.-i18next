# Copy this file to .env.local and fill in your Tolgee Cloud credentials
# Get them from: https://app.tolgee.io -> Your Project -> Project Settings -> API Keys
#
# Required Project Languages on Tolgee Cloud:
#   - English (en) [Base]
#   - French (fr)
#   - Czech (cs-CZ)
#   - Polish (pl)
#   - Russian (ru)
#   - Hindi (hi)
#   - Arabic (ar)
#
# Recommended API Key Scopes (for In-Context Editing demo):
#   - Keys: View
#   - Translations: View, Edit, Suggest
#   - Screenshots: View, Add, Delete

VITE_TOLGEE_API_URL=https://app.tolgee.io
VITE_TOLGEE_API_KEY=your_api_key_here
